# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Credential Encryption ────────────────────────────────────────────────────
# AES-256-GCM key for encrypting tenant Intacct credentials at rest.
# MUST be exactly 64 hex characters (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: changing this key after tenants have saved credentials will make
# existing credentials unreadable. Store safely — never commit to git.
CREDENTIAL_ENCRYPTION_KEY=your-64-char-hex-string

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# https://resend.com — create an API key and verify your sending domain
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Mysoft Integrations <integrations@yourdomain.com>

# ─── App ──────────────────────────────────────────────────────────────────────
# Public-facing URL — used in email links and CORS. No trailing slash.
NEXT_PUBLIC_APP_URL=https://your-deployment.vercel.app

# ─── Cron Security ────────────────────────────────────────────────────────────
# Secret passed as Bearer token to protect cron endpoints from public access.
# Set this in Vercel environment variables AND in vercel.json cron config.
# Generate with:  openssl rand -hex 32
CRON_SECRET=your-cron-secret-hex-string

# Multi-region (future — uncomment and populate when regional cells are provisioned)
# Each region requires its own Supabase project URL and service role key.
# Auth remains global (current project); regional URLs are used for data queries only.
# SUPABASE_URL_UK=https://your-uk-project.supabase.co
# SUPABASE_URL_US=https://your-us-project.supabase.co
# SUPABASE_URL_EU=https://your-eu-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY_UK=your-uk-service-role-key
# SUPABASE_SERVICE_ROLE_KEY_US=your-us-service-role-key
# SUPABASE_SERVICE_ROLE_KEY_EU=your-eu-service-role-key
