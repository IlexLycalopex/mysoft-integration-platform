{
  "MysoftAgent": {
    "ApiBaseUrl": "https://mysoft-integration-platform.vercel.app/api/v1"
  },
  "Serilog": {
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "C:\\ProgramData\\MysoftAgent\\logs\\agent-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      },
      {
        "Name": "EventLog",
        "Args": {
          "source": "MysoftIntegrationAgent",
          "logName": "Application",
          "restrictedToMinimumLevel": "Warning"
        }
      }
    ]
  }
}
